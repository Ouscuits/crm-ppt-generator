rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: admin can read/write all, user can read own doc
    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow write: if isAdmin();
    }

    // Accounts: admin can do everything, assigned users can read
    match /accounts/{accountId} {
      allow read: if isAssigned(accountId) || isAdmin();
      allow write: if isAdmin();

      // Subcollections (salesData, crmData): same permissions as parent account
      match /{subcollection}/{docId} {
        allow read: if isAssigned(accountId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAssigned(accountId) {
      return request.auth != null &&
        accountId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accounts;
    }
  }
}
